<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.SwipeDismissFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wearRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wear_screen_background">

    <androidx.wear.widget.BoxInsetLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:id="@+id/homeScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/homePage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:id="@+id/brandBadge"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:background="@drawable/wear_brand_badge">

                        <TextView
                            android:id="@+id/brandGlyph"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/brand_glyph"
                            android:textColor="@android:color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/homeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/app_name"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/homeBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="@string/companion_badge"
                        android:textColor="#89D8FF"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/homeTagline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="@string/default_detail_body"
                        android:textColor="#C2CFD9"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:id="@+id/feedCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/wear_feature_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/feedCardTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/feed_title"
                                android:textColor="@android:color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/feedSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/feed_loading"
                                android:textColor="#C2CFD9"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/feedMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/feed_meta_default"
                                android:textColor="#89D8FF"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/feedPreviewImage"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/wear_image_placeholder"
                            android:contentDescription="@string/feed_preview"
                            android:scaleType="centerCrop" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/messagesCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/wear_feature_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/messagesCardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/messages_title"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/messagesSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/messages_summary"
                            android:textColor="#C2CFD9"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/messagesMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/messages_meta_default"
                            android:textColor="#89D8FF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/mediaCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/wear_feature_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/mediaCardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/media_title"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/mediaSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/media_summary"
                            android:textColor="#C2CFD9"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/mediaMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/media_meta_default"
                            android:textColor="#89D8FF"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/homeMediaPreviousButton"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/media_prev"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />

                            <Button
                                android:id="@+id/homeMediaPlayPauseButton"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_primary_button"
                                android:text="@string/media_play_pause"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />

                            <Button
                                android:id="@+id/homeMediaNextButton"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/media_next"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                            android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/settingsCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/wear_feature_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/settingsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_title"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/settingsMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/settings_meta_default"
                            android:textColor="#89D8FF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/pageScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="18dp">

                    <Button
                        android:id="@+id/backHomeButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/wear_secondary_button"
                        android:text="@string/back_home"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/pageTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/default_detail_title"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pageBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/default_detail_body"
                        android:textColor="#C2CFD9"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:id="@+id/feedPagePanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/wear_feature_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/feedPostLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/feed_title"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/feedPageImage"
                            android:layout_width="match_parent"
                            android:layout_height="124dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/wear_image_placeholder"
                            android:contentDescription="@string/feed_preview"
                            android:scaleType="centerCrop" />

                        <TextView
                            android:id="@+id/feedPageSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/feed_loading"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/feedPageMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/feed_meta_default"
                            android:textColor="#89D8FF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/feedOpenPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/wear_feature_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/feedOpenTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/feed_latest_post_title"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/feedOpenImage"
                            android:layout_width="match_parent"
                            android:layout_height="112dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/wear_image_placeholder"
                            android:contentDescription="@string/feed_latest_post_preview"
                            android:scaleType="centerCrop" />

                        <TextView
                            android:id="@+id/feedOpenSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/feed_open_phone_summary"
                            android:textColor="#C2CFD9"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/feedOpenMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/feed_open_phone_meta"
                            android:textColor="#89D8FF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/messagesPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/wear_feature_card"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/messagesPanelTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/messages_panel_title"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/messagesPanelMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/messages_panel_default"
                            android:textColor="#C2CFD9"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:id="@+id/messagesAuthGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/watchEmailInput"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/wear_input_field"
                                android:hint="@string/watch_email_hint"
                                android:inputType="textEmailAddress"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:textColor="@android:color/white"
                                android:textColorHint="#7D93A5" />

                            <EditText
                                android:id="@+id/watchPasswordInput"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/wear_input_field"
                                android:hint="@string/watch_password_hint"
                                android:inputType="textPassword"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:textColor="@android:color/white"
                                android:textColorHint="#7D93A5" />

                            <Button
                                android:id="@+id/watchSignInButton"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/wear_primary_button"
                                android:text="@string/watch_sign_in"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/messagesThreadList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/watchSignOutButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/wear_secondary_button"
                            android:text="@string/sign_out"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/backToThreadsButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/wear_secondary_button"
                            android:text="@string/back_to_threads"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/messagesConversationPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/wear_input_field"
                            android:padding="12dp"
                            android:text="@string/messages_preview_default"
                            android:textColor="@android:color/white"
                            android:textSize="11sp"
                            android:visibility="gone" />

                        <EditText
                            android:id="@+id/watchMessageInput"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/wear_input_field"
                            android:hint="@string/watch_message_hint"
                            android:inputType="textCapSentences|textMultiLine"
                            android:maxLines="2"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:textColor="@android:color/white"
                            android:textColorHint="#7D93A5"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/watchSendMessageButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/wear_primary_button"
                            android:text="@string/watch_send_message"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/mediaPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/wear_feature_card"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/mediaPanelTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/media_panel_title"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/mediaPanelMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/media_panel_default"
                            android:textColor="#C2CFD9"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/mediaPreviousButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/media_prev"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/mediaPlayPauseButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_primary_button"
                                android:text="@string/media_play_pause"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/mediaNextButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/media_next"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                            android:textSize="12sp" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/settingsPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/wear_feature_card"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/themeMidnightButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_primary_button"
                                android:text="@string/theme_midnight"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />

                            <Button
                                android:id="@+id/themeTideButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/theme_tide"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />

                            <Button
                                android:id="@+id/themeEmberButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/theme_ember"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/themeGlacierButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/theme_glacier"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />

                            <Button
                                android:id="@+id/themeGroveButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/theme_grove"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />

                            <Button
                                android:id="@+id/themeSolarButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/theme_solar"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/notificationSettingsButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/wear_secondary_button"
                            android:text="@string/notification_settings"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />

                        <Button
                            android:id="@+id/toggleWatchNotificationsButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/wear_secondary_button"
                            android:text="@string/watch_notifications_toggle_on"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/openPhoneButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_primary_button"
                                android:text="@string/open_phone"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/refreshButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/wear_secondary_button"
                                android:text="@string/refresh"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/openSpotifyButton"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/wear_secondary_button"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="@string/open_spotify"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </FrameLayout>

    </androidx.wear.widget.BoxInsetLayout>

</androidx.wear.widget.SwipeDismissFrameLayout>
